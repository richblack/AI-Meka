{
  "name": "testing-skeleton",
  "version": "0.0.0",
  "private": true,
  "description": "AI-Meka testing skeleton — Vitest + Miniflare + Playwright",
  "type": "module",
  "scripts": {
    "test": "pnpm test:unit && pnpm test:int && pnpm test:e2e",
    "test:unit": "vitest run --project unit",
    "test:int": "vitest run --project integration",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "miniflare": "^3.20241004.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
